# Copy to .env and fill in. Bun auto-loads .env — no dotenv needed.

# Bot token from the Discord Developer Portal (Bot → Reset Token)
DISCORD_TOKEN=

# Application (client) ID from the Developer Portal (General Information)
DISCORD_APP_ID=

# Optional: register slash commands to a single guild for INSTANT updates while
# developing. Leave blank to register globally (can take up to ~1h to appear).
DEV_GUILD_ID=

# Optional: SQLite file path (default ./talkers.db)
DB_PATH=./talkers.db
